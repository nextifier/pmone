{
  "name": "LinearGradient",
  "category": "Textures",
  "description": "Create smooth linear color gradients",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#1aff00",
      "description": "The starting color of the gradient",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#0000ff",
      "description": "The ending color of the gradient",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "start": {
      "default": {
        "x": 0,
        "y": 0.5
      },
      "description": "The starting point of the gradient",
      "ui": {
        "type": "position",
        "label": "Start",
        "group": "Position"
      }
    },
    "end": {
      "default": {
        "x": 1,
        "y": 0.5
      },
      "description": "The ending point of the gradient",
      "ui": {
        "type": "position",
        "label": "End",
        "group": "Position"
      }
    },
    "angle": {
      "default": 0,
      "description": "Additional rotation angle of the gradient (in degrees)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 360,
        "step": 1,
        "label": "Angle",
        "group": "Effect"
      }
    },
    "edges": {
      "default": "stretch",
      "compileTime": true,
      "description": "How to handle areas beyond the gradient endpoints",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Stretch",
            "value": "stretch"
          },
          {
            "label": "Transparent",
            "value": "transparent"
          },
          {
            "label": "Mirror",
            "value": "mirror"
          },
          {
            "label": "Wrap",
            "value": "wrap"
          }
        ],
        "label": "Edges",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}