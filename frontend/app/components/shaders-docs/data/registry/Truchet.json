{
  "name": "Truchet",
  "category": "Textures",
  "description": "Quarter-circle arc tiles that connect to form organic, maze-like flowing curves",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#000000",
      "description": "Background color between the arcs",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ffffff",
      "description": "Arc line color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "cells": {
      "default": 10,
      "description": "Number of tiles across the shortest canvas edge",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 2,
        "max": 40,
        "step": 1,
        "label": "Cells",
        "group": "Effect"
      }
    },
    "thickness": {
      "default": 2,
      "description": "Thickness of the arc lines",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 20,
        "step": 0.1,
        "label": "Thickness",
        "group": "Effect"
      }
    },
    "seed": {
      "default": 0,
      "description": "Random seed - changes which tiles flip, producing a different maze pattern",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Seed",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}