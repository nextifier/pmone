{
  "name": "Ripples",
  "category": "Textures",
  "description": "Concentric animated ripples emanating from a point",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "The center point where ripples emanate from",
      "ui": {
        "type": "position",
        "label": "Center",
        "group": "Position"
      }
    },
    "colorA": {
      "default": "#ffffff",
      "description": "Color of the ripple waves",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#000000",
      "description": "Background color between ripples",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "speed": {
      "default": 1,
      "description": "Speed of ripple animation",
      "ui": {
        "type": "range",
        "min": -5,
        "max": 5,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "frequency": {
      "default": 20,
      "description": "Number of ripples/spacing between them",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 80,
        "step": 0.1,
        "label": "Frequency",
        "group": "Effect"
      }
    },
    "softness": {
      "default": 0,
      "description": "Softness of ripple edges",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 3,
        "step": 0.1,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "thickness": {
      "default": 0.5,
      "description": "Thickness of each ripple band",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Thickness",
        "group": "Effect"
      }
    },
    "phase": {
      "default": 0,
      "description": "Phase offset for ripple animation",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 6.28,
        "step": 0.1,
        "label": "Phase",
        "group": "Animation"
      }
    }
  }
}