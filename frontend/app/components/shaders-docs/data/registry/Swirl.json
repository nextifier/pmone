{
  "name": "Swirl",
  "category": "Textures",
  "description": "Flowing swirl pattern with multi-layered noise",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#1275d8",
      "description": "Primary gradient color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#e19136",
      "description": "Secondary gradient color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "speed": {
      "default": 1,
      "description": "Flow animation speed",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "detail": {
      "default": 1,
      "description": "Level of detail and intricacy in the swirl patterns",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 5,
        "step": 0.1,
        "label": "Detail",
        "group": "Effect"
      }
    },
    "blend": {
      "default": 50,
      "description": "Skew color balance toward A (lower values) or B (higher values)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
