{
  "name": "SimplexNoise",
  "category": "Textures",
  "description": "Organic noise with animated movement",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#ffffff",
      "description": "First color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#000000",
      "description": "Second color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    },
    "scale": {
      "default": 2,
      "description": "Pattern scale (higher = larger patterns)",
      "ui": {
        "type": "range",
        "min": -2,
        "max": 5,
        "step": 0.1,
        "label": "Scale",
        "group": "Effect"
      }
    },
    "balance": {
      "default": 0,
      "description": "Balance between colors (negative = more colorB, positive = more colorA)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -1,
        "max": 1,
        "step": 0.1,
        "label": "Balance",
        "group": "Effect"
      }
    },
    "contrast": {
      "default": 0,
      "description": "Pattern contrast (higher = sharper transitions)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -2,
        "max": 5,
        "step": 0.1,
        "label": "Contrast",
        "group": "Effect"
      }
    },
    "seed": {
      "default": 0,
      "description": "Random seed for pattern variation",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Seed",
        "group": "Effect"
      }
    },
    "speed": {
      "default": 1,
      "description": "Animation speed",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    }
  }
}