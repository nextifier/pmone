{
  "name": "Checkerboard",
  "category": "Textures",
  "description": "Classic checkerboard pattern with two alternating colors",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#cccccc",
      "description": "First color of the checkerboard pattern",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#999999",
      "description": "Second color of the checkerboard pattern",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "cells": {
      "default": 8,
      "description": "Number of cells along the shortest canvas edge (creates square cells)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 50,
        "step": 1,
        "label": "Cells",
        "group": "Effect"
      }
    },
    "softness": {
      "default": 0,
      "description": "Smoothness of the transition between colors (0 = hard edges, 1 = very soft)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}