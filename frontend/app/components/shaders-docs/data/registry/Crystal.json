{
  "name": "Crystal",
  "category": "Shape Effects",
  "description": "Diamond-like crystal lens with faceted refraction.",
  "requiresChild": true,
  "requiresRTT": true,
  "props": {
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "Center position of the crystal shape",
      "ui": {
        "type": "position",
        "label": "Center",
        "group": "Position"
      }
    },
    "scale": {
      "default": 1,
      "description": "Scale of the crystal shape (1 = default size)",
      "ui": {
        "type": "range",
        "min": 0.1,
        "max": 3,
        "step": 0.05,
        "label": "Scale",
        "group": "Position"
      }
    },
    "cutout": {
      "default": false,
      "description": "Cut out alpha outside the crystal shape",
      "ui": {
        "type": "checkbox",
        "label": "Cutout",
        "group": "Crystal"
      }
    },
    "refraction": {
      "default": 0.5,
      "description": "How strongly the crystal refracts content beneath",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 3,
        "step": 0.01,
        "label": "Refraction",
        "group": "Crystal"
      }
    },
    "dispersion": {
      "default": 0.5,
      "description": "Prismatic rainbow dispersion - splits light into spectral colors",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 2,
        "step": 0.01,
        "label": "Dispersion",
        "group": "Crystal"
      }
    },
    "facets": {
      "default": 5,
      "description": "Symmetry order - how many times the facet pattern repeats around the center",
      "ui": {
        "type": "range",
        "min": 3,
        "max": 24,
        "step": 1,
        "label": "Facets",
        "group": "Crystal"
      }
    },
    "fresnel": {
      "default": 0.05,
      "description": "Fresnel rim glow intensity around the crystal boundary",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Fresnel",
        "group": "Fresnel"
      }
    },
    "fresnelSoftness": {
      "default": 1,
      "description": "Fresnel rim width - higher values spread the glow further inward",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 2,
        "step": 0.01,
        "label": "Fresnel Softness",
        "group": "Fresnel"
      }
    },
    "fresnelColor": {
      "default": "#ffffff",
      "description": "Color of the fresnel rim glow",
      "ui": {
        "type": "color",
        "label": "Fresnel Color",
        "group": "Fresnel"
      }
    },
    "edgeSoftness": {
      "default": 0,
      "description": "Softness of the crystal boundary edge",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.05,
        "label": "Edge Softness",
        "group": "Crystal"
      }
    },
    "innerZoom": {
      "default": 1.5,
      "description": "Magnification of content seen through the crystal",
      "ui": {
        "type": "range",
        "min": 0.5,
        "max": 3,
        "step": 0.05,
        "label": "Inner Zoom",
        "group": "Crystal"
      }
    },
    "lightAngle": {
      "default": 270,
      "description": "Light direction angle in degrees",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 360,
        "step": 1,
        "label": "Light Angle",
        "group": "Lighting"
      }
    },
    "highlights": {
      "default": 0.5,
      "description": "Additive brightness on light-facing facets - never darkens",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 2,
        "step": 0.05,
        "label": "Highlights",
        "group": "Lighting"
      }
    },
    "shadows": {
      "default": 0.3,
      "description": "Darkening on shadow-facing facets - never brightens",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.05,
        "label": "Shadows",
        "group": "Lighting"
      }
    },
    "brightness": {
      "default": 1.2,
      "description": "Overall crystal brightness - higher values push facets toward brilliant white",
      "ui": {
        "type": "range",
        "min": 0.5,
        "max": 3,
        "step": 0.05,
        "label": "Brightness",
        "group": "Lighting"
      }
    },
    "tintColor": {
      "default": "#e8e0ff",
      "description": "Crystal body tint color",
      "ui": {
        "type": "color",
        "label": "Tint Color",
        "group": "Tint"
      }
    },
    "tintIntensity": {
      "default": 0,
      "description": "How much tint color is applied to the crystal interior",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Tint Intensity",
        "group": "Tint"
      }
    },
    "tintPreserveLuminosity": {
      "default": true,
      "description": "Preserve original brightness when tinting",
      "ui": {
        "type": "checkbox",
        "label": "Preserve Luminosity",
        "group": "Tint"
      }
    },
    "shape": {
      "default": "{\"type\":\"polygonSDF\",\"radius\":0.35,\"sides\":10}",
      "description": "Serialized shape configuration (JSON)",
      "ui": {
        "type": "shape",
        "label": "Shape",
        "group": "Shape"
      }
    },
    "shapeSdfUrl": {
      "default": "",
      "compileTime": true,
      "description": "URL to a pre-generated SDF .bin file"
    },
    "shapeType": {
      "default": "",
      "compileTime": true,
      "description": "Active SDF shape type"
    }
  }
}