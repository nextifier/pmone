{
  "name": "HexGrid",
  "category": "Textures",
  "description": "Honeycomb hexagonal grid pattern",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#000000",
      "description": "Cell fill color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ffffff",
      "description": "Grid line color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "cells": {
      "default": 8,
      "description": "Number of hexagons across the shortest canvas edge",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 40,
        "step": 1,
        "label": "Cells",
        "group": "Effect"
      }
    },
    "thickness": {
      "default": 1,
      "description": "Thickness of the hex grid lines",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 10,
        "step": 0.1,
        "label": "Thickness",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}