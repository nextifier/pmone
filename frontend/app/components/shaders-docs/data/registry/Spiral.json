{
  "name": "Spiral",
  "category": "Textures",
  "description": "Rotating spiral pattern with animated movement",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#000000",
      "description": "Background color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ffffff",
      "description": "Spiral stroke color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "strokeWidth": {
      "default": 0.5,
      "description": "Thickness of spiral stroke",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 2,
        "step": 0.1,
        "label": "Stroke Width",
        "group": "Effect"
      }
    },
    "strokeFalloff": {
      "default": 0,
      "description": "Stroke losing width further from center",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Stroke Falloff",
        "group": "Effect"
      }
    },
    "softness": {
      "default": 0,
      "description": "Color transition sharpness (0 = hard edge, 1 = smooth fade)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "speed": {
      "default": 1,
      "description": "Animation speed (negative values reverse direction)",
      "ui": {
        "type": "range",
        "min": -3,
        "max": 3,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "The center point of the spiral",
      "ui": {
        "type": "position",
        "label": "Center",
        "group": "Position"
      }
    },
    "scale": {
      "default": 1,
      "description": "Scale factor for spiral bands (higher = more bands, lower = fewer bands)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0.1,
        "max": 5,
        "step": 0.1,
        "label": "Scale",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}