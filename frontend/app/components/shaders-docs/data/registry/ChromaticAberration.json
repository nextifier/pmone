{
  "name": "ChromaticAberration",
  "category": "Stylize",
  "description": "Separate RGB channels for a prismatic distortion effect",
  "requiresChild": true,
  "requiresRTT": true,
  "props": {
    "strength": {
      "default": 0.2,
      "description": "Overall strength of the chromatic aberration effect",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.05,
        "label": "Strength",
        "group": "Effect"
      }
    },
    "angle": {
      "default": 0,
      "description": "Direction of the chromatic aberration in degrees",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 360,
        "step": 1,
        "label": "Angle",
        "group": "Effect"
      }
    },
    "redOffset": {
      "default": -1,
      "description": "Red channel offset multiplier",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -2,
        "max": 2,
        "step": 0.1,
        "label": "Red Offset",
        "group": "Effect"
      }
    },
    "greenOffset": {
      "default": 0,
      "description": "Green channel offset multiplier",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -2,
        "max": 2,
        "step": 0.1,
        "label": "Green Offset",
        "group": "Effect"
      }
    },
    "blueOffset": {
      "default": 1,
      "description": "Blue channel offset multiplier",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -2,
        "max": 2,
        "step": 0.1,
        "label": "Blue Offset",
        "group": "Effect"
      }
    }
  }
}