{
  "name": "ConicGradient",
  "category": "Textures",
  "description": "Colors sweep in a full circle around a center point, like a color wheel",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#FF0080",
      "description": "Starting color of the sweep",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#00BFFF",
      "description": "Ending color of the sweep (wraps back to Color A)",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "Center point of the sweep",
      "ui": {
        "type": "position",
        "label": "Center",
        "group": "Position"
      }
    },
    "rotation": {
      "default": 0,
      "description": "Rotation offset in degrees - shifts where Color A begins",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 360,
        "step": 1,
        "label": "Rotation",
        "group": "Effect"
      }
    },
    "repeat": {
      "default": 1,
      "description": "Number of times the gradient repeats around the circle. Values above 1 create a starburst pattern.",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 24,
        "step": 1,
        "label": "Repeat",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "oklch",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}