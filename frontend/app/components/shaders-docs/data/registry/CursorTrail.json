{
  "name": "CursorTrail",
  "category": "Interactive",
  "description": "Animated trail effect that tracks cursor movement",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#00aaff",
      "description": "Color of fresh trails",
      "ui": {
        "type": "color",
        "label": "Start Color",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ff00aa",
      "description": "Color trails transition to as they fade",
      "ui": {
        "type": "color",
        "label": "End Color",
        "group": "Colors"
      }
    },
    "radius": {
      "default": 0.5,
      "description": "Base radius of trail circles",
      "ui": {
        "type": "range",
        "min": 0.5,
        "max": 2,
        "step": 0.1,
        "label": "Radius",
        "group": "Effect"
      }
    },
    "length": {
      "default": 0.5,
      "description": "How long trail circles persist (in seconds)",
      "ui": {
        "type": "range",
        "min": 0.1,
        "max": 2,
        "step": 0.1,
        "label": "Trail Length",
        "group": "Animation"
      }
    },
    "shrink": {
      "default": 1,
      "description": "How much circles shrink as they fade out (0 = no shrink, 1 = full shrink)",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Shrink Amount",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}