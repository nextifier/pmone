{
  "name": "Chevron",
  "category": "Textures",
  "description": "Animated chevron / zigzag stripe pattern",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#000000",
      "description": "First color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ffffff",
      "description": "Second color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "count": {
      "default": 5,
      "description": "Number of chevron pairs visible",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 30,
        "step": 1,
        "label": "Count",
        "group": "Effect"
      }
    },
    "angle": {
      "default": 0,
      "description": "Rotation angle of the chevrons",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -180,
        "max": 180,
        "step": 1,
        "label": "Angle",
        "group": "Effect"
      }
    },
    "balance": {
      "default": 0.5,
      "description": "Ratio of the two colors",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Balance",
        "group": "Effect"
      }
    },
    "softness": {
      "default": 0,
      "description": "Edge softness",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "speed": {
      "default": 0,
      "description": "Animation speed",
      "ui": {
        "type": "range",
        "min": -2,
        "max": 2,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "offset": {
      "default": 0,
      "description": "Phase offset for pattern positioning",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Offset",
        "group": "Animation"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}