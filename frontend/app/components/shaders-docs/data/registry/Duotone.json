{
  "name": "Duotone",
  "category": "Adjustments",
  "description": "Map colors to two tones based on luminance",
  "requiresChild": true,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#ff0000",
      "description": "First color (used for darker areas)",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#023af4",
      "description": "Second color (used for brighter areas)",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "blend": {
      "default": 0.5,
      "description": "Blend point between the two colors",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Blend",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}