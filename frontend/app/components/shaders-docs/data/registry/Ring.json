{
  "name": "Ring",
  "category": "Shapes",
  "description": "Annular ring (donut) with adjustable radius and band thickness",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "color": {
      "default": "#ffffff",
      "description": "Fill color of the ring",
      "ui": {
        "type": "color",
        "label": "Color",
        "group": "Colors"
      }
    },
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "Center position of the ring",
      "ui": {
        "type": "position",
        "label": "Center",
        "group": "Position"
      }
    },
    "radius": {
      "default": 0.3,
      "description": "Distance from center to the ring's midline in UV space",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Radius",
        "group": "Shape"
      }
    },
    "thickness": {
      "default": 0.07,
      "description": "Half-width of the ring band - total ring width is twice this value",
      "ui": {
        "type": "range",
        "min": 0.005,
        "max": 0.3,
        "step": 0.005,
        "label": "Thickness",
        "group": "Shape"
      }
    },
    "softness": {
      "default": 0,
      "description": "Edge softness for antialiasing (applied to both inner and outer ring edges)",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 0.1,
        "step": 0.001,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "strokeThickness": {
      "default": 0,
      "description": "Stroke thickness. Zero means no stroke.",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 0.1,
        "step": 0.005,
        "label": "Stroke Thickness",
        "group": "Stroke"
      }
    },
    "strokeColor": {
      "default": "#000000",
      "description": "Color of the stroke outline",
      "ui": {
        "type": "color",
        "label": "Stroke Color",
        "group": "Colors"
      }
    },
    "strokePosition": {
      "default": "center",
      "description": "Position of the stroke relative to the ring edge",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Outside",
            "value": "outside"
          },
          {
            "label": "Center",
            "value": "center"
          },
          {
            "label": "Inside",
            "value": "inside"
          }
        ],
        "label": "Stroke Position",
        "group": "Stroke"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for blending fill and stroke colors",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Blending",
        "group": "Colors"
      }
    }
  }
}