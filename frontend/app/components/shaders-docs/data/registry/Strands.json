{
  "name": "Strands",
  "category": "Textures",
  "description": "Procedural wavy strands with layered animation",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "speed": {
      "default": 0.5,
      "description": "Overall animation speed",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "amplitude": {
      "default": 1,
      "description": "Wave height amplitude",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 5,
        "step": 0.1,
        "label": "Amplitude",
        "group": "Effect"
      }
    },
    "frequency": {
      "default": 1,
      "description": "Wave frequency",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 5,
        "step": 0.1,
        "label": "Frequency",
        "group": "Effect"
      }
    },
    "lineCount": {
      "default": 12,
      "description": "Number of wave lines",
      "ui": {
        "type": "range",
        "min": 4,
        "max": 32,
        "step": 1,
        "label": "Line Count",
        "group": "Effect"
      }
    },
    "lineWidth": {
      "default": 0.1,
      "description": "Width of wave lines",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.05,
        "label": "Line Width",
        "group": "Effect"
      }
    },
    "waveColor": {
      "default": "#f1c907",
      "description": "Color of the waves",
      "ui": {
        "type": "color",
        "label": "Wave Color",
        "group": "Colors"
      }
    },
    "pinEdges": {
      "default": true,
      "description": "Pin waves at edges (fade effect)",
      "ui": {
        "type": "checkbox",
        "label": "Pin Edges",
        "group": "Effect"
      }
    },
    "start": {
      "default": {
        "x": 0,
        "y": 0.5
      },
      "description": "Starting point of the waves",
      "ui": {
        "type": "position",
        "label": "Start",
        "group": "Position"
      }
    },
    "end": {
      "default": {
        "x": 1,
        "y": 0.5
      },
      "description": "Ending point of the waves",
      "ui": {
        "type": "position",
        "label": "End",
        "group": "Position"
      }
    }
  }
}