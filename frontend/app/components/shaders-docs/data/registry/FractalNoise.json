{
  "name": "FractalNoise",
  "category": "Textures",
  "description": "Multi-octave fractal Brownian motion noise texture with true noise evolution",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#000000",
      "description": "First color",
      "ui": {
        "type": "color",
        "label": "Color A",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#ffffff",
      "description": "Second color",
      "ui": {
        "type": "color",
        "label": "Color B",
        "group": "Colors"
      }
    },
    "octaves": {
      "default": 4,
      "compileTime": true,
      "description": "Number of noise octaves (more = more detail)",
      "ui": {
        "type": "range",
        "min": 1,
        "max": 8,
        "step": 1,
        "label": "Octaves",
        "group": "Effect"
      }
    },
    "detail": {
      "default": 2,
      "description": "How much finer each successive octave becomes",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 1,
        "max": 4,
        "step": 0.1,
        "label": "Detail",
        "group": "Effect"
      }
    },
    "contrast": {
      "default": 0.5,
      "description": "How strongly finer octaves contribute - higher values create more texture contrast",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0.1,
        "max": 1,
        "step": 0.05,
        "label": "Contrast",
        "group": "Effect"
      }
    },
    "speed": {
      "default": 0.15,
      "description": "Speed at which the noise pattern evolves in place",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "angle": {
      "default": 0,
      "description": "Rotation angle in degrees",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": -180,
        "max": 180,
        "step": 1,
        "label": "Angle",
        "group": "Effect"
      }
    },
    "seed": {
      "default": 0,
      "description": "Random seed for pattern variation",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Seed",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}