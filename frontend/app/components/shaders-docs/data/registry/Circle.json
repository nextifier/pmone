{
  "name": "Circle",
  "category": "Shapes",
  "description": "Generate a circle with adjustable size and softness",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "color": {
      "default": "#ffffff",
      "description": "The color of the circle",
      "ui": {
        "type": "color",
        "label": "Color",
        "group": "Colors"
      }
    },
    "radius": {
      "default": 1,
      "description": "The radius of the circle. A value of one (1) is sets the circle to fit the canvas.",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 2,
        "step": 0.05,
        "label": "Radius",
        "group": "Effect"
      }
    },
    "softness": {
      "default": 0,
      "description": "Edge softness. Lower values like zero (0) are sharp, higher values like one (1) are softer.",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Softness",
        "group": "Effect"
      }
    },
    "center": {
      "default": {
        "x": 0.5,
        "y": 0.5
      },
      "description": "The center point of the circle",
      "ui": {
        "type": "position",
        "label": "Center Position",
        "group": "Position"
      }
    },
    "strokeThickness": {
      "default": 0,
      "description": "The thickness of the stroke outline. Zero (0) means no stroke.",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 0.5,
        "step": 0.01,
        "label": "Stroke Thickness",
        "group": "Stroke"
      }
    },
    "strokeColor": {
      "default": "#000000",
      "description": "The color of the stroke outline",
      "ui": {
        "type": "color",
        "label": "Stroke Color",
        "group": "Colors"
      }
    },
    "strokePosition": {
      "default": "center",
      "description": "Position of the stroke relative to the circle edge",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Outside",
            "value": "outside"
          },
          {
            "label": "Center",
            "value": "center"
          },
          {
            "label": "Inside",
            "value": "inside"
          }
        ],
        "label": "Stroke Position",
        "group": "Stroke"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for blending fill and stroke colors in soft edges",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Blending",
        "group": "Colors"
      }
    }
  }
}