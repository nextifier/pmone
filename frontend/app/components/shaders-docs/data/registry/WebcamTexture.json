{
  "name": "WebcamTexture",
  "category": "Textures",
  "description": "Display a live webcam feed with customizable object-fit modes",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "objectFit": {
      "default": "cover",
      "description": "How the webcam feed should be sized within the viewport",
      "compileTime": true,
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Cover",
            "value": "cover"
          },
          {
            "label": "Contain",
            "value": "contain"
          },
          {
            "label": "Fill",
            "value": "fill"
          },
          {
            "label": "Scale Down",
            "value": "scale-down"
          },
          {
            "label": "None",
            "value": "none"
          }
        ],
        "label": "Object Fit",
        "group": "Appearance"
      }
    },
    "mirror": {
      "default": true,
      "description": "Mirror the webcam feed horizontally (selfie mode)",
      "ui": {
        "type": "checkbox",
        "label": "Mirror",
        "group": "Effect"
      }
    }
  }
}