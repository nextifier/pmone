{
  "name": "VideoTexture",
  "category": "Textures",
  "description": "Display a video with customizable playback and object-fit modes",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "url": {
      "default": "https://shaders.com/sample.mp4",
      "description": "Upload a video or provide a URL",
      "ui": {
        "type": "video-upload",
        "label": "Video",
        "group": "Media"
      }
    },
    "objectFit": {
      "default": "cover",
      "description": "How the video should be sized within the viewport",
      "compileTime": true,
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Cover",
            "value": "cover"
          },
          {
            "label": "Contain",
            "value": "contain"
          },
          {
            "label": "Fill",
            "value": "fill"
          },
          {
            "label": "Scale Down",
            "value": "scale-down"
          },
          {
            "label": "None",
            "value": "none"
          }
        ],
        "label": "Object Fit",
        "group": "Appearance"
      }
    },
    "loop": {
      "default": true,
      "description": "Loop the video playback",
      "ui": {
        "type": "checkbox",
        "label": "Loop",
        "group": "Playback"
      }
    }
  }
}