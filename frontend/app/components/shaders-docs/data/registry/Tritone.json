{
  "name": "Tritone",
  "category": "Adjustments",
  "description": "Map colors to three tones: shadows, midtones, highlights",
  "requiresChild": true,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#ce1bea",
      "description": "First color (used for shadows/darkest areas)",
      "ui": {
        "type": "color",
        "label": "Color A (Shadows)",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#2fff00",
      "description": "Second color (used for midtones)",
      "ui": {
        "type": "color",
        "label": "Color B (Midtones)",
        "group": "Colors"
      }
    },
    "colorC": {
      "default": "#ffff00",
      "description": "Third color (used for highlights/brightest areas)",
      "ui": {
        "type": "color",
        "label": "Color C (Highlights)",
        "group": "Colors"
      }
    },
    "blendMid": {
      "default": 0.5,
      "description": "Midpoint position between the three colors",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Midpoint",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}