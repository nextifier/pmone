{
  "name": "Glow",
  "category": "Stylize",
  "description": "Soft glow effect with adjustable intensity",
  "requiresChild": true,
  "requiresRTT": true,
  "props": {
    "intensity": {
      "default": 1,
      "description": "Glow intensity (brightness of the glow effect)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 50,
        "step": 0.5,
        "label": "Intensity",
        "group": "Effect"
      }
    },
    "threshold": {
      "default": 0.5,
      "description": "Brightness threshold for glow extraction (lower = more glow)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.05,
        "label": "Threshold",
        "group": "Effect"
      }
    },
    "size": {
      "default": 25,
      "description": "Glow spread in pixels (clean up to ~72px, mild banding above)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Glow Size",
        "group": "Effect"
      }
    }
  }
}