{
  "name": "Beam",
  "category": "Textures",
  "description": "A beam of light from one point to another.",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "startPosition": {
      "default": {
        "x": 0.2,
        "y": 0.5
      },
      "description": "Starting point of the beam",
      "ui": {
        "type": "position",
        "label": "Start Position",
        "group": "Position"
      }
    },
    "endPosition": {
      "default": {
        "x": 0.8,
        "y": 0.5
      },
      "description": "Ending point of the beam",
      "ui": {
        "type": "position",
        "label": "End Position",
        "group": "Position"
      }
    },
    "startThickness": {
      "default": 0.2,
      "description": "Thickness at the start of the beam",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 2,
        "step": 0.1,
        "label": "Start Thickness",
        "group": "Effect"
      }
    },
    "endThickness": {
      "default": 0.2,
      "description": "Thickness at the end of the beam",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 2,
        "step": 0.1,
        "label": "End Thickness",
        "group": "Effect"
      }
    },
    "startSoftness": {
      "default": 0.5,
      "description": "Edge softness at the start of the beam",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 50,
        "step": 0.1,
        "label": "Start Softness",
        "group": "Effect"
      }
    },
    "endSoftness": {
      "default": 0.5,
      "description": "Edge softness at the end of the beam",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 20,
        "step": 0.1,
        "label": "End Softness",
        "group": "Effect"
      }
    },
    "insideColor": {
      "default": "#FF0000",
      "description": "Color at the center of the beam",
      "ui": {
        "type": "color",
        "label": "Inside Color",
        "group": "Colors"
      }
    },
    "outsideColor": {
      "default": "#0000FF",
      "description": "Color at the edges of the beam",
      "ui": {
        "type": "color",
        "label": "Outside Color",
        "group": "Colors"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}