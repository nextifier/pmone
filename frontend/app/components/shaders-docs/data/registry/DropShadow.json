{
  "name": "DropShadow",
  "category": "Stylize",
  "description": "Adds a soft shadow behind the child content based on its alpha silhouette",
  "requiresChild": true,
  "requiresRTT": true,
  "props": {
    "color": {
      "default": "#000000",
      "description": "Shadow color",
      "ui": {
        "type": "color",
        "label": "Color",
        "group": "Colors"
      }
    },
    "distance": {
      "default": 0.1,
      "description": "How far the shadow is offset from the content",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.005,
        "label": "Distance",
        "group": "Effect"
      }
    },
    "angle": {
      "default": 135,
      "description": "Direction the shadow is cast (compass degrees: 0=up, 90=right, 135=lower-right, 180=down)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 360,
        "step": 1,
        "label": "Angle",
        "group": "Effect"
      }
    },
    "blur": {
      "default": 5,
      "description": "Shadow softness (blur radius in pixels)",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 20,
        "step": 0.5,
        "label": "Blur",
        "group": "Effect"
      }
    },
    "intensity": {
      "default": 0.5,
      "description": "Shadow intensity - how strong/visible the shadow is",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 1,
        "step": 0.01,
        "label": "Intensity",
        "group": "Effect"
      }
    },
    "cutout": {
      "default": false,
      "compileTime": true,
      "description": "Hide the original layer and show only the shadow",
      "ui": {
        "type": "checkbox",
        "label": "Cutout",
        "group": "Effect"
      }
    }
  }
}