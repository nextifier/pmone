{
  "name": "DiffuseBlur",
  "category": "Blurs",
  "description": "Grain-like pixel displacement at random",
  "requiresChild": true,
  "requiresRTT": true,
  "props": {
    "intensity": {
      "default": 30,
      "description": "Intensity of the diffuse blur effect",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Intensity",
        "group": "Effect"
      }
    },
    "edges": {
      "default": "stretch",
      "description": "How to handle edges when distortion pushes content out of bounds",
      "compileTime": true,
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Stretch",
            "value": "stretch"
          },
          {
            "label": "Transparent",
            "value": "transparent"
          },
          {
            "label": "Mirror",
            "value": "mirror"
          },
          {
            "label": "Wrap",
            "value": "wrap"
          }
        ],
        "label": "Edges",
        "group": "Effect"
      }
    }
  }
}