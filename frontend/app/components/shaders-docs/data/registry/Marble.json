{
  "name": "Marble",
  "category": "Textures",
  "description": "Classic marble swirl and vein texture using noise-warped sine waves",
  "requiresChild": false,
  "requiresRTT": false,
  "props": {
    "colorA": {
      "default": "#ffffff",
      "description": "Base background color of the marble",
      "ui": {
        "type": "color",
        "label": "Base",
        "group": "Colors"
      }
    },
    "colorB": {
      "default": "#3a2d54",
      "description": "Secondary marble tone",
      "ui": {
        "type": "color",
        "label": "Tone",
        "group": "Colors"
      }
    },
    "colorC": {
      "default": "#0f0f0f",
      "description": "Deepest marble color",
      "ui": {
        "type": "color",
        "label": "Depth",
        "group": "Colors"
      }
    },
    "scale": {
      "default": 2,
      "description": "Scale and density of the marble vein pattern",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0.1,
        "max": 10,
        "step": 0.1,
        "label": "Scale",
        "group": "Effect"
      }
    },
    "turbulence": {
      "default": 10,
      "description": "Amount of noise-driven distortion applied to the veins",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 50,
        "step": 0.5,
        "label": "Turbulence",
        "group": "Effect"
      }
    },
    "speed": {
      "default": 0.05,
      "description": "Animation speed",
      "ui": {
        "type": "range",
        "min": 0,
        "max": 0.25,
        "step": 0.005,
        "label": "Speed",
        "group": "Animation"
      }
    },
    "seed": {
      "default": 0,
      "description": "Random seed for pattern variation",
      "ui": {
        "type": [
          "range",
          "map"
        ],
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Seed",
        "group": "Effect"
      }
    },
    "colorSpace": {
      "default": "linear",
      "compileTime": true,
      "description": "Color space for color interpolation",
      "ui": {
        "type": "select",
        "options": [
          {
            "label": "Linear RGB",
            "value": "linear"
          },
          {
            "label": "OKLCh",
            "value": "oklch"
          },
          {
            "label": "OKLAB",
            "value": "oklab"
          },
          {
            "label": "HSL",
            "value": "hsl"
          },
          {
            "label": "HSV",
            "value": "hsv"
          },
          {
            "label": "LCH",
            "value": "lch"
          }
        ],
        "label": "Color Space",
        "group": "Colors"
      }
    }
  }
}