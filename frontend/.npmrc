# pnpm's default symlink layout (node_modules/.pnpm/<pkg>@<ver>/node_modules/<pkg>)
# trips up Nitro's Rollup output: the bundle records a relative path computed
# from the real (symlink target) location, which produces dangling references
# like `'../../../../../../../../../consola@3.4.2/node_modules/consola/dist/core.mjs'`
# when the .output bundle is run from `node .output/server/index.mjs`. The bug
# is reproducible on the dev-tunnel prod-build workflow (see CLAUDE.md). Pinning
# the node-linker to `hoisted` flattens node_modules into a classic npm-style
# layout, which Rollup resolves correctly. Real production deploys are unaffected
# because CF Pages does its own install with the same hoisting via Nixpacks.
node-linker=hoisted
