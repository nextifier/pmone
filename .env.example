# ------------------------------------------------------------------
# UNCOMMENTED keys below are the per-deployment manifest enforced by
# `php artisan env:audit` (run it in the Forge deploy script). Every
# brand deployment (pmone, monara, whitelabel) must define them all.
# Commented keys are optional/feature toggles.
# ------------------------------------------------------------------

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Read-only tunnel used by `php artisan db:pull-production` (dev tool).
# DB_PROD_HOST=127.0.0.1
# DB_PROD_PORT=5433
# DB_PROD_DATABASE=pmone
# DB_PROD_USERNAME=
# DB_PROD_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true

# Per-brand auth + CORS identity. Comma-separated, no spaces.
# Production example (monara): SANCTUM_STATEFUL_DOMAINS=monara.id
SANCTUM_STATEFUL_DOMAINS=localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://pmone.test

# Hosts allowed as payment redirect targets (config/payment.php).
# Production: the brand's admin domain + its event-website domains.
PAYMENT_TRUSTED_REDIRECT_HOSTS=localhost,pmone.test

# Brand identity for transactional output (config/brand.php).
# The display name comes from APP_NAME; these cover the rest.
BRAND_SUPPORT_EMAIL=support@pmone.id
BRAND_ICS_DOMAIN=pmone.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# RESPONSE_CACHE_ENABLED=true
# RESPONSE_CACHE_DRIVER=redis

# Brand isolation on a shared Redis instance: give each brand its own
# logical DB index AND explicit prefixes (do not rely on APP_NAME slugs).
# REDIS_DB=0
# REDIS_CACHE_DB=1
# REDIS_PREFIX=
# HORIZON_PREFIX=

# Horizon production worker sizing (config/horizon.php). Defaults match
# the historical pmone values; size new/low-traffic brands down to 1.
HORIZON_DEFAULT_MAX_PROCESSES=10
HORIZON_ANALYTICS_MAX_PROCESSES=3
HORIZON_PDF_MAX_PROCESSES=2
HORIZON_TICKETS_MAX_PROCESSES=10

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Switch freely between: log | cloudflare | resend | ses-v2
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# SMTP-only settings:
# MAIL_SCHEME=null
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null

# MAIL_MAILER=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KEY=

# MAIL_MAILER=resend
# RESEND_KEY=
# Signing secret for POST /api/webhooks/resend (Svix). Without it the endpoint
# refuses every payload.
# RESEND_WEBHOOK_SECRET=

# Media storage. Production uses the r2 disk with a per-brand bucket and
# a per-brand CDN host in AWS_URL (e.g. https://cdn.pmone.id).
MEDIA_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=
# MEDIA_PREFIX=

# Backups (config/backup.php); production only.
# BACKUP_NOTIFICATION_EMAIL=
# BACKUP_ARCHIVE_PASSWORD=

# Google Analytics fallback property (per-project GA4 lives in the DB).
# ANALYTICS_PROPERTY_ID=

# Cloudflare Turnstile (ticket checkout bot protection).
# TURNSTILE_SECRET_KEY=

# Socialite OAuth providers.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# TELESCOPE_ENABLED=false
# PERMISSIONS_AUTO_SYNC=false
# SHEETS_API_TOKEN=

VITE_APP_NAME="${APP_NAME}"

# Exchange Rate API
# API URL defaults to https://api.exchangerate-api.com/v4/latest/USD
# EXCHANGE_RATE_API_URL=
# EXCHANGE_RATE_BASE_CURRENCY=USD
# EXCHANGE_RATE_SYNC_INTERVAL=60
# EXCHANGE_RATE_CACHE_TTL=120

ANTHROPIC_API_KEY=
AI_TOTAL_CREDITS=5.00
# ANTHROPIC_ADMIN_API_KEY=

# Xendit payment gateway
# Credentials live in project_payment_gateways table (per-project, encrypted).
# Setup each project's gateway via UI: /projects/{username}/settings/payment-gateways
# Success/failure redirect URLs auto-derived from FRONTEND_URL via config/xendit.php.
# Override XENDIT_SUCCESS_REDIRECT_URL / XENDIT_FAILURE_REDIRECT_URL only if you need
# a payment gateway URL different from FRONTEND_URL (e.g., separate payment subdomain).

# WhatsApp Cloud API (Meta Graph API) - test sender for /tools/whatsapp-tester
# Permanent token via System User. PHONE_NUMBER_ID is the numeric ID, NOT the phone number.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# PDF generation (spatie/laravel-pdf + Browsershot)
#
# Production setup (run once on the server before deploying):
#   1. curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt install -y nodejs
#   2. sudo apt install -y libnss3 libxss1 libasound2 libatk-bridge2.0-0 libgbm1 \
#        libgtk-3-0 libcups2 libdrm2 libpango-1.0-0 libpangocairo-1.0-0 \
#        fonts-liberation fonts-noto-color-emoji fonts-noto-cjk
#      (Ubuntu 24.04: replace libasound2 with libasound2t64)
#   3. sudo npm install -g puppeteer@^23
#   4. sudo npx puppeteer browsers install chrome
#   5. Set LARAVEL_PDF_CHROME_PATH to the path printed by step 4
#
# Forge deploy script should include:  npm ci --omit=dev && npm run build
# Post-deploy verification:            php artisan pdf:smoke-test
#
# Driver: browsershot (default) | dompdf | gotenberg | cloudflare | chrome | weasyprint
LARAVEL_PDF_DRIVER=browsershot
# Absolute paths required in production. Leave blank locally to auto-detect.
LARAVEL_PDF_NODE_BINARY=
LARAVEL_PDF_CHROME_PATH=
# LARAVEL_PDF_NPM_BINARY=
# LARAVEL_PDF_NODE_MODULES_PATH=
# Set true only if AppArmor/seccomp blocks Chromium sandbox on the server.
LARAVEL_PDF_NO_SANDBOX=false

# Frontend public API key for the accommodation page (frontend/.env for dev).
# NUXT_PM_ONE_API_KEY=
