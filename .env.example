APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

RESPONSE_CACHE_ENABLED=true

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Exchange Rate API
# API URL defaults to https://api.exchangerate-api.com/v4/latest/USD
# EXCHANGE_RATE_API_URL=
EXCHANGE_RATE_BASE_CURRENCY=USD
EXCHANGE_RATE_SYNC_INTERVAL=60
EXCHANGE_RATE_CACHE_TTL=120

ANTHROPIC_API_KEY=
AI_TOTAL_CREDITS=5.00

# Xendit payment gateway
# Credentials live in project_payment_gateways table (per-project, encrypted).
# Setup each project's gateway via UI: /projects/{username}/settings/payment-gateways
# Success/failure redirect URLs auto-derived from FRONTEND_URL via config/xendit.php.
# Override XENDIT_SUCCESS_REDIRECT_URL / XENDIT_FAILURE_REDIRECT_URL only if you need
# a payment gateway URL different from FRONTEND_URL (e.g., separate payment subdomain).

# PDF generation (spatie/laravel-pdf + Browsershot)
#
# Production setup (run once on the server before deploying):
#   1. curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt install -y nodejs
#   2. sudo apt install -y libnss3 libxss1 libasound2 libatk-bridge2.0-0 libgbm1 \
#        libgtk-3-0 libcups2 libdrm2 libpango-1.0-0 libpangocairo-1.0-0 \
#        fonts-liberation fonts-noto-color-emoji fonts-noto-cjk
#      (Ubuntu 24.04: replace libasound2 with libasound2t64)
#   3. sudo npm install -g puppeteer@^23
#   4. sudo npx puppeteer browsers install chrome
#   5. Set LARAVEL_PDF_CHROME_PATH to the path printed by step 4
#
# Forge deploy script should include:  npm ci --omit=dev && npm run build
# Post-deploy verification:            php artisan pdf:smoke-test
#
# Driver: browsershot (default) | dompdf | gotenberg | cloudflare | chrome | weasyprint
LARAVEL_PDF_DRIVER=browsershot
# Absolute paths required in production. Leave blank locally to auto-detect.
LARAVEL_PDF_NODE_BINARY=
LARAVEL_PDF_CHROME_PATH=
# Set true only if AppArmor/seccomp blocks Chromium sandbox on the server.
LARAVEL_PDF_NO_SANDBOX=false

# PM One frontend public API key (for accommodation page)
NUXT_PM_ONE_API_KEY=
